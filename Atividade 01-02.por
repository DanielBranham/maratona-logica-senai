programa {
  funcao inicio() {
    inteiro parafuso1, parafuso2, total

    escreva("Digite o numero da primeira remessa: ")
    leia(parafuso1)

    escreva("Digite o numero da segunda remessa: ")
    leia(parafuso2)

    total=parafuso1+parafuso2

    escreva("O total em estoque é: ",total)
  }
}

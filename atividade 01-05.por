programa {
  funcao inicio() {
    real kwh1, kwh2, khw3, media

    escreva("Digite o consumo da primeira maquina: ")
    leia(kwh1)

    escreva("Digite o consumo da segunda maquina: ")
    leia(kwh2)

    escreva("Digite o consumo da terceira maquina: ")
    leia(khw3)

    media=(kwh1+kwh2+khw3)/3

    escreva("a media de consumo das maquinas é: ",media)
  }
}

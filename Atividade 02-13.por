programa {
  funcao inicio() {
    inteiro setorA, setorb

    escreva("Digite a produção do setor A: ")
    leia(setorA)

    escreva("Digite a produção do setor B: ")
    leia(setorb)

    se(setorA>setorb){

      escreva("O setor A produziu mais que o setor B")

    }

    senao se (setorb>setorA)

    escreva("O setor B produziu mais que o setor A")
    
    senao

    escreva("Os dois setores produziram a mesma quantidade de peça")
    

    
    }


  }
}
